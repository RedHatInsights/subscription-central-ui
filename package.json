{
  "name": "subscription-central",
  "version": "0.0.1",
  "private": false,
  "scripts": {
    "analyze": "npm run build:prod && source-map-explorer 'dist/js/*.js'",
    "build": "fec build",
    "deploy": "npm-run-all build:prod lint test",
    "format": "prettier \"src/**/*.{js,tsx,html,scss}\" --write",
    "lint": "npm-run-all lint:*",
    "lint:js": "eslint config src",
    "lint:js:fix": "eslint config src --fix",
    "lint:sass": "stylelint 'src/**/*.scss' --config .stylelintrc.json",
    "lint:staged": "pretty-quick --staged && lint-staged",
    "nightly": "npm run deploy",
    "postisntall": "rm -rf .cache",
    "prepare": "husky install",
    "server:ctr": "node src/server/generateServerKey.js",
    "start": "PROXY=true fec dev",
    "test": "TZ=UTC jest --verbose --no-cache",
    "test:watch": "jest --watch",
    "verify": "npm-run-all build lint test",
    "fec": "fec build",
    "postinstall": "ts-patch install"
  },
  "overrides": {
    "glob-parent": "^6.0.1",
    "hosted-git-info": "^3.0.8",
    "url-parse": "^1.5.3",
    "moment": "2.30.1"
  },
  "lint-staged": {
    "*.{js,scss,ts,tsx,html}": "eslint --cache --fix"
  },
  "jest": {
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/stories/*",
      "!src/App.js",
      "!src/AppEntry.js",
      "!src/bootstrap-dev.js",
      "!src/bootstrap.js",
      "!src/entry-dev.js",
      "!src/entry.js",
      "!src/Routes.tsx"
    ],
    "coverageDirectory": "./coverage/",
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 85,
        "statements": 80
      }
    },
    "moduleNameMapper": {
      "\\.(css|scss)$": "identity-obj-proxy"
    },
    "clearMocks": true,
    "roots": [
      "<rootDir>/src/"
    ],
    "setupFiles": [
      "<rootDir>/config/setupTests.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "testEnvironment": "jsdom",
    "testRunner": "jest-jasmine2",
    "transformIgnorePatterns": [
      "/node_modules/(?!(@patternfly|uuid))"
    ]
  },
  "dependencies": {
    "@patternfly/react-core": "^6.2.0",
    "@patternfly/react-icons": "^6.3.1",
    "@patternfly/react-table": "^6.2.0",
    "@project-kessel/react-kessel-access-check": "^0.5.1",
    "@redhat-cloud-services/frontend-components": "^7.3.1",
    "@redhat-cloud-services/frontend-components-utilities": "^7.2.0",
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "semver": "^7.7.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.0",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
    "@babel/plugin-syntax-dynamic-import": "7.8.3",
    "@babel/plugin-transform-runtime": "^8.0.0",
    "@babel/preset-env": "^8.0.0",
    "@babel/preset-flow": "8.0.1",
    "@babel/preset-react": "8.0.1",
    "@babel/preset-typescript": "^8.0.0",
    "@faker-js/faker": "^9.8.0",
    "@redhat-cloud-services/eslint-config-redhat-cloud-services": "^3.0.0",
    "@redhat-cloud-services/frontend-components-config": "^6.8.3",
    "@redhat-cloud-services/tsc-transform-imports": "^1.2.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.0.44",
    "@types/react-dom": "^18.3.1",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.45.0",
    "babel-plugin-lodash": "^3.3.4",
    "babel-plugin-transform-imports": "^2.0.0",
    "bdd-lazy-var": "^2.6.1",
    "css-loader": "^7.0.0",
    "eslint": "^9.24.0",
    "fishery": "^2.2.2",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.6.1",
    "jest-environment-jsdom": "^30.3.0",
    "jest-fetch-mock": "^3.0.3",
    "jest-jasmine2": "^29.6.1",
    "lint-staged": "^16.1.0",
    "npm-run-all2": "5.0.2",
    "prettier": "^3.6.2",
    "pretty-quick": "^4.2.2",
    "source-map-explorer": "^2.5.3",
    "stylelint": "^16.21.0",
    "stylelint-config-recommended-scss": "^14.1.0",
    "stylelint-scss": "^6.12.0",
    "ts-patch": "^3.2.1",
    "typescript": "^5.0.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "insights": {
    "appname": "manifests"
  }
}
